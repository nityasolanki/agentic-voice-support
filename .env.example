# ── LLM ──────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# ── Voice ─────────────────────────────────────────
DEEPGRAM_API_KEY=your_deepgram_api_key
CARTESIA_API_KEY=your_cartesia_api_key

# ── PostgreSQL ────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=support_db
POSTGRES_USER=support_user
POSTGRES_PASSWORD=support_pass

# ── Qdrant ────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=knowledge_base

# ── Twilio ────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_FROM_NUMBER=+1234567890
TWILIO_WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok-free.app

# ── Gmail API ────────────────────────────────────
GMAIL_CREDENTIALS_FILE=config/gmail_credentials.json
GMAIL_SENDER_EMAIL=support@yourbusiness.com

# ── App ──────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
SESSION_SECRET=change-me-in-production
FRONTEND_URL=http://localhost:8501
